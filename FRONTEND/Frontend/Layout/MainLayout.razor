@inherits LayoutComponentBase
@inject AuthService AuthService
@inject HttpClient Http

<div class="page-container">
    <nav class="navbar">
        <div class="navbar-inner">

            <div class="nav-brand">
                <NavLink href="/">
                    @* Tady stačí vyměnit logo.png za tvůj nahraný obrázek *@
                    <img src="imgs/logo.png" alt="SportCentrum" style="height: 50px; margin: 4px;" />
                </NavLink>
            </div>

            <div class="nav-links">
                <NavLink href="/sports" class="button1">Sporty</NavLink>
                <NavLink href="/facilities" class="button1">Sportoviště</NavLink>
                <NavLink href="/equipment" class="button1">Vybavení</NavLink> @* PŘIDANÉ TLAČÍTKO *@
                <NavLink href="/reservation" class="button1">Rezervace</NavLink>
            </div>

            <div class="nav-auth">
                @if (isLoggedIn)
                {
                    <NavLink href="/profile" class="button1">
                        <i class="fa-solid fa-user"></i> Profil
                    </NavLink>
                    <button class="button1 btn-logout" @onclick="Logout">
                        <i class="fa-solid fa-right-from-bracket"></i> Odhlášení
                    </button>
                }
                else
                {
                    <NavLink href="/login" class="button1">
                        <i class="fa-solid fa-right-to-bracket"></i> Přihlášení
                    </NavLink>
                    <NavLink href="/register" class="button1">
                        <i class="fa-solid fa-user-plus"></i> Registrace
                    </NavLink>
                }
            </div>

        </div>
    </nav>

    <main class="main">
        <div class="container">
            @Body
        </div>
    </main>

    <footer class="footer">
        <div class="footer-inner">

            <div class="footer-top">

                <div class="footer-col footer-brand">
                    <h2>SportCentrum</h2>
                    <p style="font-size: 0.85rem; opacity: 0.7; margin-top: 10px;">
                        Vaše místo pro sport a relaxaci v srdci města.
                    </p>
                </div>

                <div class="footer-col">
                    <h4>Rezervace</h4>
                    <p><NavLink href="/facilities" style="color: inherit; text-decoration: none;">Dostupná sportoviště</NavLink></p>
                    <p><NavLink href="/reservation" style="color: inherit; text-decoration: none;">Online kalendář</NavLink></p>
                    <p><NavLink href="/equipment" style="color: inherit; text-decoration: none;">Půjčovna vybavení</NavLink></p>
                </div>

                <div class="footer-col">
                    <h4>Informace</h4>
                    <p>Ceník služeb</p>
                    <p>Návštěvní řád</p>
                    <p>Ochrana osobních údajů</p>
                </div>

                <div class="footer-col">
                    <h4>Kontakt</h4>
                    <p><i class="fa-solid fa-envelope"></i> info@sportcentrum.cz</p>
                    <p><i class="fa-solid fa-phone"></i> +420 123 456 789</p>
                    <p><i class="fa-solid fa-location-dot"></i> Sportovní 123, Ostrava</p>
                </div>

            </div>

            <div class="footer-bottom">
                <div>
                    © 2026 SportCentrum Ostrava. Všechna práva vyhrazena.
                </div>

                <div class="footer-social">
                    <i class="fa-brands fa-facebook"></i>
                    <i class="fa-brands fa-instagram"></i>
                    <i class="fa-brands fa-youtube"></i>
                    <i class="fa-brands fa-tiktok"></i>
                </div>
            </div>

        </div>
    </footer>
</div>

@code {
    bool isLoggedIn;

    protected override async Task OnInitializedAsync()
    {
        isLoggedIn = await AuthService.IsLoggedIn();
    }

    async Task Logout()
    {
        await AuthService.Logout(Http);
        isLoggedIn = false;
        Navigation.NavigateTo("/", true);
    }

    [Inject] NavigationManager Navigation { get; set; } = default!;
}