@page "/register"
@using Frontend.DTO
@inject HttpClient Http
@inject NavigationManager Nav

<div class="card">
    <h1>Registrace</h1>

    <div class="form1">

        <input class="input1"
               placeholder="Email"
               @bind="model.Email" />

        <input class="input1"
               placeholder="Celé jméno"
               @bind="model.FullName" />

        <input type="password"
               class="input1"
               placeholder="Heslo"
               @bind="model.Password" />

        <button class="button2" style="width:200px" @onclick="RegisterUser">
            Registrovat <i class="fa-solid fa-user-plus"></i>
        </button>

        @if (!string.IsNullOrEmpty(message))
        {
            <p>@message</p>
        }

    </div>
</div>




@code {
    CreateUserRequestDto model = new();

    string? message;

    async Task RegisterUser()
    {
        message = null;

        if (string.IsNullOrWhiteSpace(model.Email) || string.IsNullOrWhiteSpace(model.Password))
        {
            message = "Vyplň email a heslo!";
            return;
        }

        var response = await Http.PostAsJsonAsync("users", model);

        if (response.IsSuccessStatusCode)
        {
            var user = await response.Content.ReadFromJsonAsync<UserResponseDto>();

            message = $"Registrace úspěšná! ID: {user?.Id}";

            Nav.NavigateTo("/login");
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            message = $"Chyba: {error}";
        }
    }
}