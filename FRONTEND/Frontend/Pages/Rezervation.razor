@code {
    private List<FacilityResponseDto> facilities = new();
    private List<SportDto> availableSports = new();
    private List<ReservationResponseDto> allReservations = new();
    private List<EquipmentResponseDto> allEquipment = new();
    private Dictionary<int, int> selectedEquipment = new();

    private int selectedFacilityId = 0;
    private int selectedSportId = 0;
    private DateTime startOfWeek;
    private DateTime selectedSlot;

    private bool showModal = false;
    private bool isUserLoggedIn = false;

    protected override async Task OnInitializedAsync()
    {
        startOfWeek = GetMonday(DateTime.Today);
        await CheckUserStatus();

        try
        {
            facilities = await Http.GetFromJsonAsync<List<FacilityResponseDto>>("facilities") ?? new();
            allEquipment = await Http.GetFromJsonAsync<List<EquipmentResponseDto>>("equipments") ?? new();

            var uri = Nav.ToAbsoluteUri(Nav.Uri);
            if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("facilityId", out var facilityIdVal))
            {
                if (int.TryParse(facilityIdVal, out var id))
                {
                    selectedFacilityId = id;
                    await LoadFacilityData(id);
                }
            }
        }
        catch (Exception ex) { Console.WriteLine("Data Load Error: " + ex.Message); }
    }

    private async Task CheckUserStatus()
    {
        var token = await AuthService.GetToken();
        isUserLoggedIn = !string.IsNullOrEmpty(token);
    }

    private async Task HandleFacilityChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            selectedFacilityId = id;
            await LoadFacilityData(id);
        }
        else
        {
            selectedFacilityId = 0;
            selectedSportId = 0;
            availableSports.Clear();
        }
    }

    private async Task LoadFacilityData(int facilityId)
    {
        selectedSportId = 0;
        var fac = facilities.FirstOrDefault(f => f.Id == facilityId);
        availableSports = fac?.Sports ?? new();

        if (availableSports.Count == 1)
        {
            selectedSportId = availableSports[0].Id;
        }

        await LoadReservations();
    }

    private async Task LoadReservations()
    {
        if (selectedFacilityId == 0) return;
        try
        {
            var res = await Http.GetFromJsonAsync<List<ReservationResponseDto>>("Reservations") ?? new();
            allReservations = res.Where(r => r.FacilityId == selectedFacilityId && r.Status != "CANCELLED").ToList();
        }
        catch { }
    }

    private bool CheckIfReserved(DateTime slot) => allReservations.Any(r => r.StartAt <= slot && r.EndAt > slot);

    private async Task OpenBookingModal(DateTime slot)
    {
        await CheckUserStatus();
        if (!isUserLoggedIn) return;

        selectedSlot = slot;
        selectedEquipment.Clear(); // Reset výběru vybavení při každém otevření
        showModal = true;
    }

    private void AddEquipment(int id)
    {
        if (!selectedEquipment.ContainsKey(id)) selectedEquipment[id] = 0;
        selectedEquipment[id]++;
    }
    private void RemoveEquipment(int id)
    {
        if (selectedEquipment.ContainsKey(id) && selectedEquipment[id] > 0)
        {
            selectedEquipment[id]--;
        }
    }

    private async Task ConfirmBooking()
    {
        var user = await AuthService.GetUser();
        var token = await AuthService.GetToken();
        if (user == null || string.IsNullOrEmpty(token)) return;

        var dto = new CreateReservationRequestDto
        {
            UserId = user.Id,
            FacilityId = selectedFacilityId,
            SportId = selectedSportId,
            StartAt = selectedSlot,
            EndAt = selectedSlot.AddHours(1)
        };

        var request = new HttpRequestMessage(HttpMethod.Post, "Reservations") { Content = JsonContent.Create(dto) };
        request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token.Trim('"'));

        var response = await Http.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var createdRes = await response.Content.ReadFromJsonAsync<ReservationResponseDto>();

            // Odeslání požadavků na vybavení
            foreach (var eq in selectedEquipment.Where(x => x.Value > 0))
            {
                var rentalDto = new
                {
                    EquipmentId = eq.Key,
                    ReservationId = createdRes.Id,
                    Qty = eq.Value
                };
                await Http.PostAsJsonAsync("equipmentrentals", rentalDto);
            }

            showModal = false;
            Nav.NavigateTo("/profile");
        }
    }

    private DateTime GetMonday(DateTime day)
    {
        int diff = (7 + (day.DayOfWeek - DayOfWeek.Monday)) % 7;
        return day.AddDays(-1 * diff).Date;
    }
    private void PrevWeek() => startOfWeek = startOfWeek.AddDays(-7);
    private void NextWeek() => startOfWeek = startOfWeek.AddDays(7);
}