@page "/reservation"
@using Frontend.DTO
@using System.Net.Http.Json
@using System.Globalization
@inject HttpClient Http
@inject AuthService AuthService
@inject NavigationManager Nav

@{
    string[] dnyTyden = { "Pondělí", "Úterý", "Středa", "Čtvrtek", "Pátek", "Sobota", "Neděle" };
}

<div class="reservation-page">
    <div class="reservation-container">

        <div class="header-section">
            <h1 class="main-title">Rezervace sportoviště</h1>
            <p class="sub-title">Vyberte si sportoviště a volný čas pro váš trénink.</p>
        </div>

        @* SELECTION ROW *@
        <div class="selection-grid shadow-sm two-cols">
            <div class="selection-item">
                <label>1. Vyberte sportoviště</label>
                <select class="form-select-modern" @onchange="HandleFacilityChange">
                    <option value="0">-- vyberte sportoviště --</option>
                    @foreach (var f in facilities)
                    {
                        <option value="@f.Id" selected="@(f.Id == selectedFacilityId)">@f.Name</option>
                    }
                </select>
            </div>

            <div class="selection-item">
                <label>2. Vyberte sport</label>
                <select class="form-select-modern" @bind="selectedSportId" disabled="@(selectedFacilityId == 0)">
                    <option value="0">-- vyberte sport --</option>
                    @foreach (var s in availableSports)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>
        </div>

        @* LOGIN NOTICE *@
        @if (!isUserLoggedIn && selectedFacilityId > 0 && selectedSportId > 0)
        {
            <div class="login-notice-warning shadow-sm">
                <div class="notice-content">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <div>
                        <strong>Rezervace je přístupná pouze přihlášeným uživatelům.</strong><br />
                        <span>Vyberte si termín a poté se přihlaste k dokončení objednávky.</span>
                    </div>
                </div>
                <div class="notice-actions">
                    <a href="/login" class="btn-notice-login">Přihlásit se</a>
                    <a href="/register" class="btn-notice-register">Registrace</a>
                </div>
            </div>
        }

        @* WEEKLY GRID *@
        <div class="scheduler-wrapper">
            @if (selectedFacilityId > 0 && selectedSportId > 0)
            {
                <div class="scheduler-card shadow-sm">
                    <div class="scheduler-nav">
                        <button class="btn-nav-arrow" @onclick="PrevWeek"><i class="fa-solid fa-chevron-left"></i></button>
                        <span class="nav-label">
                            @startOfWeek.ToString("dd. MM.") – @startOfWeek.AddDays(6).ToString("dd. MM. yyyy")
                        </span>
                        <button class="btn-nav-arrow" @onclick="NextWeek"><i class="fa-solid fa-chevron-right"></i></button>
                    </div>

                    <div class="table-responsive">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th class="time-header">Čas</th>
                                    @for (int i = 0; i < 7; i++)
                                    {
                                        var date = startOfWeek.AddDays(i);
                                        <th class="@(date.Date == DateTime.Today ? "col-today-header" : "")">
                                            <div class="day-name">@dnyTyden[i]</div>
                                            <div class="day-date">@date.ToString("dd.MM.")</div>
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @for (int hour = 8; hour <= 20; hour++)
                                {
                                    <tr>
                                        <td class="time-cell">@hour:00</td>
                                        @for (int day = 0; day < 7; day++)
                                        {
                                            var slotTime = startOfWeek.AddDays(day).Date.AddHours(hour);
                                            var isReserved = CheckIfReserved(slotTime);
                                            var isPast = slotTime < DateTime.Now;

                                            <td class="@(startOfWeek.AddDays(day).Date == DateTime.Today ? "col-today-cell" : "")">
                                                @if (isReserved)
                                                {
                                                    <div class="slot-reserved">Obsazeno</div>
                                                }
                                                else if (isPast)
                                                {
                                                    <div class="slot-past">-</div>
                                                }
                                                else
                                                {
                                                    <button class="btn-slot-free @(!isUserLoggedIn ? "locked" : "")"
                                                            @onclick="() => OpenBookingModal(slotTime)"
                                                            disabled="@(!isUserLoggedIn)">
                                                        Volno
                                                    </button>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="empty-state-card shadow-sm">
                    <div class="empty-state-content">
                        <div class="icon-circle">
                            <i class="fa-solid fa-arrow-pointer"></i>
                        </div>
                        <h3>@(selectedFacilityId == 0 ? "Vyberte sportoviště" : "Vyberte sport")</h3>
                        <p>
                            @(selectedFacilityId == 0
                                                    ? "Nejprve vyberte konkrétní sportoviště v horní liště, aby se mohl zobrazit rozvrh." 
                                                                    : "Nyní prosím vyberte sport, který chcete provozovat, aby se načetla obsazenost.")
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@* DIALOG PRO POTVRZENÍ S VÝBĚREM VYBAVENÍ *@
@if (showModal)
{
    <div class="modal-overlay">
        <div class="modal-content-modern shadow-lg">
            <div class="modal-header-simple">
                <h3>Potvrzení rezervace</h3>
                <button class="btn-close-simple" @onclick="() => showModal = false">&times;</button>
            </div>
            <div class="modal-body-simple">
                <div class="slot-summary">
                    <span class="slot-label">Vybraný termín:</span>
                    @{
                        string[] mesice = { "", "ledna", "února", "března", "dubna", "května", "června", "července", "srpna", "září", "října", "listopadu", "prosince" };
                        int indexDne = ((int)selectedSlot.DayOfWeek + 6) % 7;
                        string ceskyDen = dnyTyden[indexDne];
                        string ceskeDatum = $"{selectedSlot.Day}. {mesice[selectedSlot.Month]}";
                    }
                    <span class="slot-value">@ceskyDen @ceskeDatum v @selectedSlot.ToString("HH:00")</span>
                </div>

                @* SEKCE VYBAVENÍ *@
                <div class="equipment-selection">
                    <label class="section-label">Potřebujete zapůjčit vybavení?</label>
                    <div class="equipment-mini-list">
                        @if (allEquipment == null || !allEquipment.Any())
                        {
                            <p class="text-muted small">Žádné vybavení není momentálně k dispozici.</p>
                        }
                        else
                        {
                            @foreach (var item in allEquipment.Where(x => x.QuantityAvailable > 0))
                            {
                                <div class="eq-mini-item">
                                    <span class="eq-name">@item.Name <small>(@item.PricePerHour Kč/h)</small></span>
                                    <div class="eq-controls">
                                        <button class="btn-qty" @onclick="() => RemoveEquipment(item.Id)">-</button>
                                        <span class="eq-count">@(selectedEquipment.GetValueOrDefault(item.Id, 0))</span>
                                        <button class="btn-qty" @onclick="() => AddEquipment(item.Id)">+</button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="modal-actions-simple">
                    <button class="btn-secondary-flat" @onclick="() => showModal = false">Zrušit</button>
                    <button class="btn-primary-flat" @onclick="ConfirmBooking">Potvrdit a rezervovat</button>
                </div>
            </div>
        </div>
    </div>
}

