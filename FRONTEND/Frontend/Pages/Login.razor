@page "/login"
@inject HttpClient Http
@inject NavigationManager Nav
@using Frontend.DTO
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<div class="login-page">
    <div class="login-main-container">

        @* HEADER SEKCE - Sjednoceno s ostatními stránkami *@
        <div class="header-section">
            <h1 class="main-title">Přihlášení</h1>
            <p class="sub-title">Zadejte své údaje pro přístup k rezervačnímu systému.</p>
        </div>

        <div class="login-wide-card shadow-sm">
            <div class="login-form-layout">

                @* LEVÁ STRANA: FORMULÁŘ *@
                <div class="login-inputs">
                    <div class="input-field">
                        <label>E-mailová adresa</label>
                        <input type="email" class="input-modern" placeholder="jmeno@email.cz" @bind="email" />
                    </div>

                    <div class="input-field">
                        <label>Heslo</label>
                        <input type="password" class="input-modern" placeholder="Zadejte své heslo" @bind="password" />
                    </div>

                    @if (!string.IsNullOrEmpty(message))
                    {
                        <div class="error-text">
                            <i class="fa-solid fa-circle-exclamation"></i> @message
                        </div>
                    }
                </div>

                @* PRAVÁ STRANA: TLAČÍTKO A ODKAZ *@
                <div class="login-actions">
                    <button class="btn-login-main" @onclick="LogMeIn">
                        Přihlásit se <i class="fa-solid fa-arrow-right"></i>
                    </button>
                    <div class="register-link">
                        Nemáte ještě účet? <a href="/register">Registrujte se</a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --brand: #2563eb;
        --brand-dark: #1e293b;
        --text-main: #334155;
        --text-light: #64748b;
        --bg-page: #f8fafc;
        --border-soft: #e2e8f0;
    }

    .login-page {
        background-color: var(--bg-page);
        min-height: 85vh;
        padding: 4rem 0;
        color: var(--text-main);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    .login-main-container {
        width: 1000px; /* Sjednoceno s šířkou /sports a /facilities */
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    /* Header - Přesná kopie tvých schválených stránek */
    .header-section {
        margin-bottom: 3rem;
        border-left: 4px solid var(--brand);
        padding-left: 1.5rem;
    }

    .main-title {
        font-size: 2rem;
        font-weight: 700;
        color: var(--brand-dark);
        letter-spacing: -0.5px;
    }

    .sub-title {
        color: var(--text-light);
        font-size: 1rem;
        margin-top: 0.25rem;
        line-height: 1.5;
    }

    /* Wide Card */
    .login-wide-card {
        background: white;
        border-radius: 1rem;
        border: 1px solid var(--border-soft);
        padding: 3.5rem;
    }

    /* Grid layout */
    .login-form-layout {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 5rem;
        align-items: center;
    }

    /* Levá strana */
    .login-inputs {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
    }

    .input-field label {
        display: block;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--text-light);
        margin-bottom: 0.6rem;
        letter-spacing: 1px;
    }

    .input-modern {
        width: 100%;
        padding: 0.8rem 1.1rem;
        border-radius: 0.5rem;
        border: 1px solid var(--border-soft);
        font-size: 1rem;
        background: #fcfcfc;
        transition: all 0.2s;
    }

        .input-modern:focus {
            outline: none;
            border-color: var(--brand);
            background: white;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.05);
        }

    /* Pravá strana */
    .login-actions {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        border-left: 1px solid var(--border-soft);
        padding-left: 5rem;
        text-align: center;
    }

    .btn-login-main {
        background: var(--brand);
        color: white;
        border: none;
        padding: 1rem 2rem;
        border-radius: 0.6rem;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        transition: transform 0.2s, background 0.2s;
    }

        .btn-login-main:hover {
            background: #1d4ed8;
            transform: translateY(-2px);
        }

    .register-link {
        font-size: 0.95rem;
        color: var(--text-light);
    }

        .register-link a {
            color: var(--brand);
            text-decoration: none;
            font-weight: 700;
        }

            .register-link a:hover {
                text-decoration: underline;
            }

    .error-text {
        background: #fef2f2;
        color: #dc2626;
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        font-size: 0.85rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border: 1px solid #fee2e2;
    }

    /* Responzivita */
    @@media (max-width: 900px) {
        .login-main-container {
            width: 100%;
        }

        .login-form-layout {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        .login-actions {
            border-left: none;
            padding-left: 0;
            padding-top: 2.5rem;
            border-top: 1px solid var(--border-soft);
        }
    }
</style>

@code {
    string email = "";
    string password = "";
    string? message;

    async Task LogMeIn()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("users/login", new { Email = email, Password = password });

            if (!response.IsSuccessStatusCode)
            {
                message = "Špatný e-mail nebo heslo.";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
            if (result?.Token != null)
            {
                await LocalStorage.SetItemAsync("token", result.Token);
                await LocalStorage.SetItemAsync("user", result.User);
                Nav.NavigateTo("/", true);
            }
        }
        catch { message = "Došlo k chybě při komunikaci se serverem."; }
    }
}